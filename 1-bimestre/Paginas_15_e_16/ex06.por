programa
{
    funcao inicio()
    {
        real peso_quilos, peso_gramas

        escreva("Digite o peso em quilos: ")
        leia(peso_quilos)

        peso_gramas = peso_quilos * 1000

        escreva("\nPeso em quilos: ", peso_quilos)
        escreva("\nPeso em gramas: ", peso_gramas)
    }
}
