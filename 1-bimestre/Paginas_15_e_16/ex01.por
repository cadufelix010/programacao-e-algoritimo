programa
{
    funcao inicio()
    {
        inteiro cavalos, ferraduras

        escreva("Digite a quantidade de cavalos: ")
        leia(cavalos)

        ferraduras = cavalos * 4

        escreva("\nQuantidade de cavalos: ", cavalos)
        escreva("\nQuantidade de ferraduras necessárias: ", ferraduras)
    }
}
